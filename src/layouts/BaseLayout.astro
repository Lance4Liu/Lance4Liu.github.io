---
import '../styles/theme.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '小柳飞刀 · Personal Site',
  description = 'P5R-inspired personal homepage and blog'
} = Astro.props as Props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:ital,wght@0,400;0,600;0,700;1,700&family=Noto+Sans+SC:wght@400;500;700;900&family=Bebas+Neue&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-bg" aria-hidden="true"></div>
    <slot />
  </body>
</html>
