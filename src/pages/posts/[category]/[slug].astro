---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const categoryLabels = {
  tech: '学习笔记',
  product: '产品思考',
  diary: '产品测评'
} as const;

const pageMeta = {
  tech: { title: 'AI Notes', cn: '学习笔记' },
  product: { title: 'PM thinking', cn: '产品思考' },
  diary: { title: 'AI takes', cn: '产品测评' }
} as const;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { category: post.data.category, slug: post.slug },
    props: { post }
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props as Props;
const { Content } = await render(post);

const allPosts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const categories = [
  {
    key: 'tech' as const,
    label: categoryLabels.tech,
    count: allPosts.filter((item) => item.data.category === 'tech').length,
    active: post.data.category === 'tech'
  },
  {
    key: 'product' as const,
    label: categoryLabels.product,
    count: allPosts.filter((item) => item.data.category === 'product').length,
    active: post.data.category === 'product'
  },
  {
    key: 'diary' as const,
    label: categoryLabels.diary,
    count: allPosts.filter((item) => item.data.category === 'diary').length,
    active: post.data.category === 'diary'
  }
];

const recentPosts = allPosts.slice(0, 5).map((item) => ({
  title: item.data.title,
  href: `/posts/${item.data.category}/${item.slug}`,
  date: item.data.date.toISOString().slice(5, 10),
  active: item.id === post.id
}));

const currentPageMeta = pageMeta[post.data.category];
---

<ArticleLayout
  title={post.data.title}
  categoryLabel={categoryLabels[post.data.category]}
  date={post.data.date.toISOString().slice(0, 10)}
  author="小柳飞刀"
  readingTime={post.data.readingTime ?? '5 分钟阅读'}
  pageTitle={currentPageMeta.title}
  pageCn={currentPageMeta.cn}
  categories={categories}
  recentPosts={recentPosts}
>
  <Content />
</ArticleLayout>
